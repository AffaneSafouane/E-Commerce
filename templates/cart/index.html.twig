{% extends 'base.html.twig' %}

{% block title %}Panier{% endblock %}

{% block body %}
<div class="example-wrapper">
    <h1>Votre panier</h1>

    <table>
        {# Loop through the 'cart' array. For each item, display product name, quantity, unit price, and total line price. #}
        {% for item in items %}
            <tr>
                <td>{{ item.product.name }}</td>
                <td>{{ item.quantity }}</td>
                <td>{{ item.product.price }}</td>
                <td>{{ item.quantity * item.product.price }}</td>
            </tr>
        {% endfor %}
        <tr>
            <td colspan="3">Total</td>
            <td>{{ total }}</td>
        </tr>
    </table>
</div>
{% endblock %}
