{% extends 'base.html.twig' %}

{% block title %}
    Profil
{% endblock %}

{% block body %}
    <h1>Profil</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ user.id }}</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>{{ user.email }}</td>
            </tr>
            <tr>
                <th>Roles</th>
                <td>{{ user.roles ? user.roles|json_encode : '' }}</td>
            </tr>
            <tr>
                <th>Password</th>
                <td>{{ user.password }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ user.name }}</td>
            </tr>
            <tr>
                <th>FirstName</th>
                <td>{{ user.firstName }}</td>
            </tr>
            {{ if user.phone is not null }}
            <tr>
                <th>Phone</th>
                <td>{{ user.phone }}</td>
            </tr>
            {{ endif }}
            <tr>
                <th>Adresse de livraison</th>
                <td>
                    {% if user.deliveryAddress %}
                        {{ user.deliveryAddress.firstName }} {{ user.deliveryAddress.name }}<br>
                        {{ user.deliveryAddress.address }}<br>
                        {{ user.deliveryAddress.cp }} {{ user.deliveryAddress.city }}
                    {% else %}
                        <span class="text-muted">Aucune adresse de livraison renseignée.</span>
                    {% endif %}
                </td>
            </tr>
            <tr>
                <th>Adresse de facturation</th>
                <td>
                    {% if user.billingAddress %}
                        {{ user.billingAddress.address }}<br>
                        {{ user.billingAddress.city }}
                    {% else %}
                        <span class="text-muted">Identique à la livraison (ou non renseignée).</span>
                    {% endif %}
                </td>
            </tr>
        </tbody>
    </table>

    <a href="javascript:history.back()">Retour</a>

    <a href="{{ path('app_profil_edit') }}">Modifier</a>
    <a href="{{ path('app_change_password') }}">Modifier mot de passe</a>

    {{ include('profil/_delete_form.html.twig') }}
{% endblock %}
