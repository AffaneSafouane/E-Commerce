{% extends 'base.html.twig' %}

{% block title %}
    Profil
{% endblock %}

{% block body %}    
    <h1 class="mt-3">Profil</h1>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    <table class="table">
        <tbody>
            <tr>
                <th>Email</th>
                <td>{{ user.email }}</td>
            </tr>
            <tr>
                <th>Roles</th>
                <td>{{ user.roles ? user.roles|json_encode : '' }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ user.name }}</td>
            </tr>
            <tr>
                <th>FirstName</th>
                <td>{{ user.firstName }}</td>
            </tr>
            {% if user.phone is not null %}
                <tr>
                    <th>Phone</th>
                    <td>{{ user.phone }}</td>
                </tr>
            {% endif %}
            <tr>
                <th>Adresse de livraison</th>
                <td>
                    {% set delivery = user.deliveryAddress %}
                    {% if delivery %}
                        <strong>{{ delivery.name }}</strong><br>
                        {{ delivery.address }}<br>
                        {{ delivery.postalCode }} {{ delivery.city }}
                    {% else %}
                        <span class="text-muted">Aucune adresse de livraison.</span>
                    {% endif %}
                </td>
            </tr>
            <tr>
                <th>Adresse de facturation</th>
                <td>
                    {% set billing = user.billingAddress %}
                    {% set delivery = user.deliveryAddress %}

                    {% if billing.id == delivery.id %}
                        <span class="text-muted">Identique à la livraison.</span>
                    {% else %}
                        <strong>{{ billing.name }}</strong><br>
                        {{ billing.address }}<br>
                        {{ billing.postalCode }} {{ billing.city }}
                    {% endif %}
                </td>
            </tr>
        </tbody>
    </table>

    <div class="d-flex justify-content-between">
        <a href="{{ path('app_profil_edit') }}" class="btn btn-warning">Modifier</a>
        <a href="{{ path('app_change_password') }}" class="btn btn-warning">Modifier mot de passe</a>

        <div class="delete-form-wrapper">
            {{ include('profil/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
